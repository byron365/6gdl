---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VozLector from '../../components/VozLector.jsx';
import TablaContenido from '../../components/TablaContenido.astro';
import MarcarLeido from '../../components/MarcarLeido.jsx';
import SimuladorRR from '../../components/SimuladorRR.jsx';
import SimuladorRotacion from '../../components/SimuladorRotacion.jsx';
import ConstructorDH from '../../components/ConstructorDH.jsx';
import SimuladorSCARA from '../../components/SimuladorSCARA.jsx';
import BloquePractica from '../../components/BloquePractica.jsx';
import RobotAnim3D from '../../components/RobotAnim3D.jsx';
import EsquemaRobot from '../../components/EsquemaRobot.jsx';
import Donacion from '../../components/Donacion.astro';
import { simuladoresDe } from '../../data/simuladores.js';
import { bancoDe } from '../../data/banco.js';
import toc from '../../data/toc.json';

export async function getStaticPaths() {
  const capitulos = await getCollection('capitulos');
  // ordenar por número de capítulo
  const ordenados = capitulos.sort((a, b) => a.data.numero - b.data.numero);

  return ordenados.map((cap, i) => ({
    params: { slug: cap.id },
    props: {
      cap,
      anterior: i > 0 ? ordenados[i - 1] : null,
      siguiente: i < ordenados.length - 1 ? ordenados[i + 1] : null,
    },
  }));
}

const { cap, anterior, siguiente } = Astro.props;
const { Content, headings } = await render(cap);
const { titulo, numero, parteNumero, parteTitulo } = cap.data;
const totalCaps = toc.totalCapitulos;
const sims = simuladoresDe(cap.data.slug);
const banco = bancoDe(cap.data.slug);

// función para slugificar el encabezado destino (coincide con ids de Astro)
function anclaDe(texto) {
  return (texto || '')
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-')
    .replace(/[^\p{L}\p{N}-]+/gu, '')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');
}
---

<BaseLayout titulo={`${numero}. ${titulo}`} descripcion={`Capítulo ${numero}: ${titulo}. Parte ${parteNumero} — ${parteTitulo}.`}>
  <div class="read-progress" role="presentation"></div>

  <div class="page-wrap chapter-layout" id="chapterLayout">
    <!-- Botones para colapsar/expandir laterales -->
    <button class="lateral-toggle toggle-izq" id="toggleIzq" aria-label="Ocultar índice de capítulos" title="Ocultar índice de capítulos">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button class="lateral-toggle toggle-der" id="toggleDer" aria-label="Ocultar índice de la página" title="Ocultar índice de la página">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <!-- Sidebar: índice de capítulos -->
    <aside class="chapter-aside">
      <nav aria-label="Capítulos">
        {toc.partes.map((parte) => (
          <div class="aside-parte">
            <p class="aside-parte-title">Parte {parte.numero}</p>
            <ul>
              {parte.capitulos.map((c) => (
                <li>
                  <a
                    href={`/capitulos/${c.slug}`}
                    class={c.numero === numero ? 'aside-link active' : 'aside-link'}
                    aria-current={c.numero === numero ? 'page' : undefined}
                  >
                    <span class="aside-n">{String(c.numero).padStart(2, '0')}</span>
                    {c.titulo}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Contenido del capítulo -->
    <article class="chapter">
      <header class="chapter-head">
        <p class="eyebrow">Parte {parteNumero} · {parteTitulo}</p>
        <div class="chapter-title-row">
          <span class="chapter-bignum">{String(numero).padStart(2, '0')}</span>
          <h1>{titulo}</h1>
        </div>
      </header>

      <VozLector client:only="react" targetSelector=".prose" />

      <div class="prose">
        <Content />
      </div>

      {cap.data.slug === 'cap-03-clasificacion-de-los-robots' && (
        <div id="robot-anims-pool" style="position:absolute; left:-9999px; top:0; width:400px;">
          <div data-anim-tipo="cartesiano"><RobotAnim3D client:only="react" tipo="cartesiano" /></div>
          <div data-anim-tipo="cilindrico"><RobotAnim3D client:only="react" tipo="cilindrico" /></div>
          <div data-anim-tipo="polar"><RobotAnim3D client:only="react" tipo="polar" /></div>
          <div data-anim-tipo="scara"><RobotAnim3D client:only="react" tipo="scara" /></div>
          <div data-anim-tipo="articulado"><RobotAnim3D client:only="react" tipo="articulado" /></div>
          <div data-esq-tipo="cartesiano"><EsquemaRobot client:load tipo="cartesiano" /></div>
          <div data-esq-tipo="cilindrico"><EsquemaRobot client:load tipo="cilindrico" /></div>
          <div data-esq-tipo="polar"><EsquemaRobot client:load tipo="polar" /></div>
          <div data-esq-tipo="scara"><EsquemaRobot client:load tipo="scara" /></div>
          <div data-esq-tipo="articulado"><EsquemaRobot client:load tipo="articulado" /></div>
        </div>
      )}

      {sims.map((sim) => (
        <section
          class="sim-bloque"
          data-tras-ancla={sim.trasEncabezado ? anclaDe(sim.trasEncabezado) : ''}
        >
          <p class="eyebrow">Simulador interactivo</p>
          <h3 class="sim-bloque-titulo">{sim.titulo}</h3>
          {sim.descripcion && <p class="sim-bloque-desc">{sim.descripcion}</p>}
          {sim.componente === 'SimuladorRR' && <SimuladorRR client:visible />}
          {sim.componente === 'SimuladorRotacion' && <SimuladorRotacion client:visible />}
          {sim.componente === 'ConstructorDH' && <ConstructorDH client:visible />}
          {sim.componente === 'SimuladorSCARA' && <SimuladorSCARA client:only="react" />}
        </section>
      ))}

      {banco && (
        <section class="practica-seccion">
          <p class="eyebrow">Practica lo aprendido</p>
          <h3 class="sim-bloque-titulo">Pon a prueba tu comprensión</h3>
          <BloquePractica client:visible banco={banco} />
        </section>
      )}

      <MarcarLeido client:only="react" slug={cap.data.slug} total={totalCaps} />

      <Donacion />

      <!-- Navegación previo / siguiente -->
      <nav class="chapter-nav" aria-label="Navegación entre capítulos">
        {anterior ? (
          <a href={`/capitulos/${anterior.data.slug}`} class="nav-card prev">
            <span class="nav-dir">← Anterior</span>
            <span class="nav-title">{anterior.data.numero}. {anterior.data.titulo}</span>
          </a>
        ) : <span></span>}
        {siguiente ? (
          <a href={`/capitulos/${siguiente.data.slug}`} class="nav-card next">
            <span class="nav-dir">Siguiente →</span>
            <span class="nav-title">{siguiente.data.numero}. {siguiente.data.titulo}</span>
          </a>
        ) : <span></span>}
      </nav>
    </article>

    <!-- Índice de la página (scroll-spy) -->
    <TablaContenido headings={headings} />
  </div>

  <script>
    import { setupDiagrams, setupReadProgress } from '../../lib/client.js';
    setupReadProgress();
    setupDiagrams();

    // Reubicar mini-animaciones de robot en sus marcadores del contenido
    (function () {
      const pool = document.getElementById('robot-anims-pool');
      if (!pool) return;
      const colocar = () => {
        let movidas = 0;
        // animaciones 3D
        document.querySelectorAll('[data-robot-anim]').forEach((marca) => {
          const tipo = marca.getAttribute('data-robot-anim');
          const fuente = pool.querySelector(`[data-anim-tipo="${tipo}"]`);
          if (fuente && fuente.firstElementChild) {
            marca.replaceWith(fuente.firstElementChild);
            movidas++;
          }
        });
        // esquemas SVG
        document.querySelectorAll('[data-robot-esquema]').forEach((marca) => {
          const tipo = marca.getAttribute('data-robot-esquema');
          const fuente = pool.querySelector(`[data-esq-tipo="${tipo}"]`);
          if (fuente && fuente.firstElementChild) {
            marca.replaceWith(fuente.firstElementChild);
            movidas++;
          }
        });
        // si ya no quedan marcadores, retirar el pool
        const restantes = document.querySelectorAll('[data-robot-anim],[data-robot-esquema]').length;
        if (restantes === 0) pool.remove();
        return movidas;
      };
      // las islas pueden tardar en hidratar; reintentar hasta colocar todo
      let intentos = 0;
      const iv = setInterval(() => {
        colocar();
        const quedan = document.querySelectorAll('[data-robot-anim],[data-robot-esquema]').length;
        if (quedan === 0 || ++intentos > 25) clearInterval(iv);
      }, 150);
    })();

    // Colapsar/expandir laterales para ampliar el área de lectura
    (function () {
      const layout = document.getElementById('chapterLayout');
      const bIzq = document.getElementById('toggleIzq');
      const bDer = document.getElementById('toggleDer');
      if (!layout) return;

      // restaurar preferencia
      try {
        if (localStorage.getItem('ra-izq-oculto') === '1') layout.classList.add('izq-oculto');
        if (localStorage.getItem('ra-der-oculto') === '1') layout.classList.add('der-oculto');
      } catch (e) {}

      bIzq?.addEventListener('click', () => {
        const oculto = layout.classList.toggle('izq-oculto');
        bIzq.setAttribute('aria-label', oculto ? 'Mostrar índice de capítulos' : 'Ocultar índice de capítulos');
        try { localStorage.setItem('ra-izq-oculto', oculto ? '1' : '0'); } catch (e) {}
      });
      bDer?.addEventListener('click', () => {
        const oculto = layout.classList.toggle('der-oculto');
        bDer.setAttribute('aria-label', oculto ? 'Mostrar índice de la página' : 'Ocultar índice de la página');
        try { localStorage.setItem('ra-der-oculto', oculto ? '1' : '0'); } catch (e) {}
      });
    })();
  </script>

  <style>
    .chapter-layout {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr) 200px;
      gap: 2.5rem;
      padding-top: 2rem;
      align-items: start;
      position: relative;
      transition: grid-template-columns 0.3s ease;
    }
    /* estados colapsados: la columna correspondiente pasa a 0 */
    .chapter-layout.izq-oculto { grid-template-columns: 0 minmax(0, 1fr) 200px; }
    .chapter-layout.der-oculto { grid-template-columns: 240px minmax(0, 1fr) 0; }
    .chapter-layout.izq-oculto.der-oculto { grid-template-columns: 0 minmax(0, 1fr) 0; }
    .chapter-layout.izq-oculto .chapter-aside,
    .chapter-layout.der-oculto :global(.toc) {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    /* al ocultar un lateral, el contenido se centra con ancho cómodo de lectura */
    .chapter-layout.izq-oculto .chapter,
    .chapter-layout.der-oculto .chapter {
      max-width: 760px;
      margin-inline: auto;
      width: 100%;
    }
    .chapter-layout.izq-oculto.der-oculto .chapter { max-width: 820px; }

    /* botones de colapsar laterales: fijos, siguen el scroll */
    .lateral-toggle {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      z-index: 60;
      width: 1.9rem;
      height: 2.6rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--line-strong);
      background: color-mix(in srgb, var(--bg-elevated) 92%, transparent);
      backdrop-filter: blur(8px);
      color: var(--ink-faint);
      cursor: pointer;
      transition: all 0.18s ease;
      opacity: 0.55;
    }
    .lateral-toggle:hover { color: var(--accent); border-color: var(--accent); opacity: 1; }
    .toggle-izq { left: 0; border-radius: 0 var(--radius-sm) var(--radius-sm) 0; border-left: none; }
    .toggle-der { right: 0; border-radius: var(--radius-sm) 0 0 var(--radius-sm); border-right: none; }
    .chapter-layout.izq-oculto .toggle-izq svg { transform: rotate(180deg); }
    .chapter-layout.der-oculto .toggle-der svg { transform: rotate(180deg); }
    .lateral-toggle svg { transition: transform 0.2s ease; }
    .chapter-aside, .chapter-layout :global(.toc) { transition: opacity 0.25s ease; }

    /* sidebar */
    .chapter-aside {
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      padding-right: 0.5rem;
    }
    .aside-parte { margin-bottom: 1.5rem; }
    .aside-parte-title {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .chapter-aside ul { list-style: none; padding: 0; }
    .aside-link {
      display: flex;
      gap: 0.6rem;
      padding: 0.4rem 0.6rem;
      border-radius: var(--radius-sm);
      font-size: 0.85rem;
      color: var(--ink-soft);
      border-left: 2px solid transparent;
      line-height: 1.35;
    }
    .aside-link:hover { background: var(--surface); color: var(--ink); }
    .aside-link.active {
      color: var(--accent);
      background: var(--accent-glow);
      border-left-color: var(--accent);
      font-weight: 500;
    }
    .aside-n { font-family: var(--font-mono); color: var(--ink-faint); font-size: 0.78rem; }
    .aside-link.active .aside-n { color: var(--accent); }

    /* cabecera del capítulo */
    .chapter { min-width: 0; }
    .chapter-head { margin-bottom: 2rem; }
    .chapter-title-row {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-top: 0.5rem;
    }
    .chapter-bignum {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 700;
      color: var(--line-strong);
      line-height: 1;
    }

    /* navegación inferior */
    .chapter-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--line);
    }
    .nav-card {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 1rem 1.25rem;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    .nav-card:hover { border-color: var(--accent); background: var(--surface-hover); }
    .nav-card.next { text-align: right; }
    .nav-dir {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent);
    }
    .nav-title { font-family: var(--font-display); font-weight: 500; color: var(--ink); font-size: 0.95rem; }

    @media (max-width: 1100px) {
      .chapter-layout { grid-template-columns: 240px minmax(0, 1fr); }
      .chapter-layout > :global(.toc) { display: none; }
      .toggle-der { display: none; }
      .chapter-layout.izq-oculto { grid-template-columns: 0 minmax(0, 1fr); }
    }
    @media (max-width: 900px) {
      .chapter-layout { grid-template-columns: 1fr; }
      .lateral-toggle { display: none; }
      .chapter-aside {
        position: static;
        max-height: none;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1rem;
        margin-bottom: 1.5rem;
      }
      .chapter-nav { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
