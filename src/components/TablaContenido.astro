---
// Índice "En esta página": lista los h2/h3 del capítulo y resalta
// la sección visible mientras se hace scroll (scroll-spy).
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
// Solo nivel 2 y 3 para no saturar
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{items.length > 0 && (
  <nav class="toc" aria-label="En esta página">
    <p class="toc-title">En esta página</p>
    <ul>
      {items.map((h) => (
        <li class={h.depth === 3 ? 'toc-sub' : ''}>
          <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    font-size: 0.85rem;
    padding-left: 1rem;
    border-left: 1px solid var(--line);
  }
  .toc-title {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.75rem;
  }
  .toc ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .toc-sub { padding-left: 0.85rem; }
  .toc a {
    display: block;
    padding: 0.25rem 0;
    color: var(--ink-faint);
    line-height: 1.35;
    border-left: 2px solid transparent;
    margin-left: -1rem;
    padding-left: 1rem;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .toc a:hover { color: var(--ink-soft); }
  .toc a.active {
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 500;
  }
</style>

<script>
  // Scroll-spy con IntersectionObserver
  function initTocSpy() {
    const links = Array.from(document.querySelectorAll('[data-toc-link]'));
    if (!links.length) return;

    const byId = new Map();
    links.forEach((l) => byId.set(l.getAttribute('data-toc-link'), l));

    const headings = links
      .map((l) => document.getElementById(l.getAttribute('data-toc-link')))
      .filter(Boolean);

    let activeId = null;
    const setActive = (id) => {
      if (id === activeId) return;
      activeId = id;
      links.forEach((l) => l.classList.remove('active'));
      const link = byId.get(id);
      if (link) link.classList.add('active');
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // tomar el heading visible más alto en la página
        const visibles = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visibles.length) {
          setActive(visibles[0].target.id);
        }
      },
      { rootMargin: '-80px 0px -65% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  initTocSpy();
</script>
