---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import Buscador from '../components/Buscador.jsx';

interface Props {
  titulo: string;
  descripcion?: string;
}

const { titulo, descripcion = 'Aprende robótica, cinemática y los fundamentos matemáticos de los manipuladores de forma interactiva.' } = Astro.props;
const tituloCompleto = `${titulo} · 6 GDL`;
// Enlace de donaciones Ko-fi. Si no defines PUBLIC_KOFI_USER, usa un placeholder.
const kofiUser = import.meta.env.PUBLIC_KOFI_USER || 'tuusuario';
const kofiUrl = `https://ko-fi.com/${kofiUser}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={descripcion} />
    {/* Favicons 6 GDL — se adaptan al tema del navegador (claro/oscuro) */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logos/favicon-32.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logos/favicon-dark-32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logos/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/logos/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/logos/favicon-512.png" />

    <!-- KaTeX para las fórmulas (servido localmente, sin depender de CDN) -->
    <link rel="stylesheet" href="/katex/katex.min.css" />

    <title>{tituloCompleto}</title>

    {/* Google Analytics 4 — se incluye solo si defines PUBLIC_GA_ID en tu entorno.
        Para activarlo: crea un archivo .env con  PUBLIC_GA_ID="G-XXXXXXXXXX"
        (tu ID de medición de GA4). Sin esa variable, no se carga nada. */}
    {import.meta.env.PUBLIC_GA_ID && (
      <>
        <script
          is:inline
          src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}
          async
        ></script>
        <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
          {`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', gaId);
          `}
        </script>
      </>
    )}

    <!-- Evitar parpadeo de tema: aplicar antes del render -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('ra-theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        const theme = saved || (prefersLight ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="page-wrap header-inner">
        <a href="/" class="brand" aria-label="6 GDL — Inicio">
          <img class="brand-logo brand-logo-light" src="/logos/logo-light-nav.png" srcset="/logos/logo-light-nav.png 1x, /logos/logo-light-2x-nav.png 2x" alt="6 GDL" width="158" height="50" />
          <img class="brand-logo brand-logo-dark" src="/logos/logo-dark-nav.png" srcset="/logos/logo-dark-nav.png 1x, /logos/logo-dark-2x-nav.png 2x" alt="6 GDL" width="158" height="50" />
        </a>

        <nav class="site-nav" aria-label="Principal">
          <a href="/">Inicio</a>
          <a href="/temario">Temario</a>
          <a href="/simuladores">Simuladores</a>
          <a href={kofiUrl} class="nav-kofi" target="_blank" rel="noopener" title="Apoya el proyecto">
            <span class="nav-kofi-emoji" aria-hidden="true">☕</span>
            <span class="nav-kofi-text">Invítame un café</span>
          </a>
          <Buscador client:load />
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="page-wrap footer-inner">
        <p>6 GDL — Manual interactivo de robótica y cinemática.</p>
        <p class="footer-faint">Contenido en construcción · Fase 2</p>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 4rem;
      }
      .brand {
        display: flex;
        align-items: center;
      }
      .brand-logo {
        height: 42px;
        width: auto;
        display: block;
      }
      /* mostrar el logo según el tema activo del sitio */
      .brand-logo-dark { display: none; }
      :global([data-theme='dark']) .brand-logo-light { display: none; }
      :global([data-theme='dark']) .brand-logo-dark { display: block; }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .site-nav a {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--ink-soft);
      }
      .site-nav a:hover { color: var(--accent); }
      .nav-kofi {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.85rem;
        background: var(--accent-glow);
        border: 1px solid var(--accent);
        border-radius: 999px;
        color: var(--accent) !important;
        font-weight: 600;
        font-size: 0.88rem;
        transition: all 0.15s ease;
      }
      .nav-kofi:hover {
        background: var(--accent);
        color: #1a1205 !important;
        transform: translateY(-1px);
      }
      .nav-kofi-emoji { font-size: 1rem; }
      @media (max-width: 720px) {
        .nav-kofi-text { display: none; }
        .nav-kofi { padding: 0.35rem 0.6rem; }
      }

      .site-footer {
        margin-top: 5rem;
        border-top: 1px solid var(--line);
        padding: 2rem 0;
      }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--ink-faint);
      }
      .footer-faint { font-family: var(--font-mono); font-size: 0.75rem; }

      @media (max-width: 600px) {
        .site-nav { gap: 1rem; }
        .brand-logo { height: 34px; }
      }
    </style>
  </body>
</html>
